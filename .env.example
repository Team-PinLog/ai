# FastAPI AI 서버 설정 예시. 실제 값은 .env(gitignore)나 배포 환경변수로 주입한다.
# Embedding Profile 4종은 기본값이 없다 — 누락 시 기동 실패(model-profile.md §2).

# DB (ai 스키마 전용 롤. core.* 권한 없음)
DATABASE_URL=postgresql://ai_app:CHANGME@localhost:5432/pinlog

# GMS 게이트웨이 (임베딩=OpenAI 호환, 판정=Gemini 네이티브)
GMS_API_KEY=CHANGME
GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1

# Embedding Profile (단일 주입. 세 토큰이 profile 문자열과 일치해야 기동)
PINLOG_EMBEDDING_MODEL=text-embedding-3-small
PINLOG_EMBEDDING_DIMENSION=1536
PINLOG_EMBEDDING_DISTANCE=cosine
PINLOG_EMBEDDING_PROFILE=openai-text-embedding-3-small-1536-cosine-v1

# LLM 판정 (E2에서 사용)
PINLOG_JUDGE_MODEL=gemini-2.5-flash

# 후보 검색 파라미터 (테스트 C 확정값)
KEYWORD_CANDIDATE_TOP_K=10
SIMILARITY_FLOOR=0.30

# PROCESSING 재선점 만료 — Spring 재스캔 만료와 동일 값 주입(임의값 금지)
PROCESSING_EXPIRY_SEC=600

# Preset 캐시 TTL
PRESET_CACHE_TTL_SEC=600

# 서비스 간 공유 시크릿 (내부 API 인증)
INTERNAL_SHARED_SECRET=CHANGME
